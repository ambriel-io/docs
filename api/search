ype":"text","url":"/docs/ui/fraud/digital-footprint#device-identification","content":"Track unique devices across web and mobile platforms, linking activity across multiple sessions."},"487":{"id":"/docs/ui/fraud/digital-footprint-13","page_id":"/docs/ui/fraud/digital-footprint","type":"text","url":"/docs/ui/fraud/digital-footprint#device-safety-and-security-checks","content":"Verify the security status of a device before allowing access to your platform. This ensures that your users are legitimate and not using compromised devices."},"488":{"id":"/docs/ui/fraud/digital-footprint-14","page_id":"/docs/ui/fraud/digital-footprint","type":"text","url":"/docs/ui/fraud/digital-footprint#real-time-location-tracking","content":"Track the real-time location of users, allowing you to ensure that their geolocation matches expected behavior. This is essential for spotting suspicious access attempts or potential fraud."},"489":{"id":"/docs/ui/fraud/digital-footprint-15","page_id":"/docs/ui/fraud/digital-footprint","type":"text","url":"/docs/ui/fraud/digital-footprint#network-and-connection-monitoring","content":"Monitor the user's network and connection details to identify suspicious activity and prevent fraud."},"490":{"id":"/docs/ui/fraud/digital-footprint-16","page_id":"/docs/ui/fraud/digital-footprint","type":"text","url":"/docs/ui/fraud/digital-footprint#analyzing-software-hardware-environment-and-screen-data","content":"Verify the authenticity of devices and detect potential tampering or manipulation by analyzing the software, hardware, and screen data of each user device."},"491":{"id":"/docs/ui/fraud/digital-footprint-17","page_id":"/docs/ui/fraud/digital-footprint","type":"text","url":"/docs/ui/fraud/digital-footprint#behavioral--environmental-analysis","content":"Monitor user behavior in real-time and flag deviations that could indicate fraudulent or automated activities."},"492":{"id":"/docs/ui/fraud/digital-footprint-18","page_id":"/docs/ui/fraud/digital-footprint","type":"text","url":"/docs/ui/fraud/digital-footprint#geofencing-for-location-based-regulation-compliance-igaming","content":"Integrate with real-time location tracking to validate that transactions align with local regulations, ensuring compliance while blocking suspicious attempts to manipulate location data."},"493":{"id":"/docs/ui/fraud/fraud","page_id":"/docs/ui/fraud/fraud","type":"page","content":"Getting Started","url":"/docs/ui/fraud/fraud"},"494":{"id":"/docs/ui/fraud/fraud-0","page_id":"/docs/ui/fraud/fraud","type":"text","url":"/docs/ui/fraud/fraud","content":"Ambriel is a comprehensive suite of fraud prevention and compliance solutions."},"495":{"id":"/docs/ui/fraud/fraud-1","page_id":"/docs/ui/fraud/fraud","type":"heading","url":"/docs/ui/fraud/fraud#what-can-you-do-with-ambriel","content":"What can you do with Ambriel?"},"496":{"id":"/docs/ui/fraud/fraud-2","page_id":"/docs/ui/fraud/fraud","type":"heading","url":"/docs/ui/fraud/fraud#how-can-you-use-ambriel","content":"How can you use Ambriel?"},"497":{"id":"/docs/ui/fraud/fraud-3","page_id":"/docs/ui/fraud/fraud","type":"heading","url":"/docs/ui/fraud/fraud#fraud-prevention","content":"Fraud Prevention"},"498":{"id":"/docs/ui/fraud/fraud-4","page_id":"/docs/ui/fraud/fraud","type":"heading","url":"/docs/ui/fraud/fraud#device-intelligence","content":"Device Intelligence"},"499":{"id":"/docs/ui/fraud/fraud-5","page_id":"/docs/ui/fraud/fraud","type":"heading","url":"/docs/ui/fraud/fraud#aml-and-compliance","content":"AML and Compliance"},"500":{"id":"/docs/ui/fraud/fraud-6","page_id":"/docs/ui/fraud/fraud","type":"heading","url":"/docs/ui/fraud/fraud#products","content":"Products"},"501":{"id":"/docs/ui/fraud/fraud-7","page_id":"/docs/ui/fraud/fraud","type":"text","url":"/docs/ui/fraud/fraud","content":"Ambriel is a comprehensive suite of fraud prevention and compliance solutions tailored for financial services, fintechs, iGaming operators, e-commerce platforms, retailers, and other digital businesses seeking effective risk management tools."},"502":{"id":"/docs/ui/fraud/fraud-8","page_id":"/docs/ui/fraud/fraud","type":"text","url":"/docs/ui/fraud/fraud#what-can-you-do-with-ambriel","content":"Safeguard your operations from financial crime"},"503":{"id":"/docs/ui/fraud/fraud-9","page_id":"/docs/ui/fraud/fraud","type":"text","url":"/docs/ui/fraud/fraud#what-can-you-do-with-ambriel","content":"Make informed decisions"},"504":{"id":"/docs/ui/fraud/fraud-10","page_id":"/docs/ui/fraud/fraud","type":"text","url":"/docs/ui/fraud/fraud#what-can-you-do-with-ambriel","content":"Meet regulatory compliance requirements with greater efficiency"},"505":{"id":"/docs/ui/fraud/fraud-11","page_id":"/docs/ui/fraud/fraud","type":"text","url":"/docs/ui/fraud/fraud#how-can-you-use-ambriel","content":"You can use Ambriel's tools individually for targeted needs or as part of a complete risk management strategy. Whether tackling transactional fraud, identifying synthetic identities, or ensuring AML compliance, Ambriel delivers data clarity and actionable insights."},"506":{"id":"/docs/ui/fraud/fraud-12","page_id":"/docs/ui/fraud/fraud","type":"text","url":"/docs/ui/fraud/fraud#fraud-prevention","content":"Ambriel's primary fraud prevention tool is the Fraud API, a versatile and modular API that consolidates digital footprinting, decisioning, and risk scoring capabilities into a single, streamlined response. This unified structure allows businesses to submit data inputs and receive enriched insights, rule evaluations, and risk scores in real-time, enabling effective security strategies."},"507":{"id":"/docs/ui/fraud/fraud-13","page_id":"/docs/ui/fraud/fraud","type":"text","url":"/docs/ui/fraud/fraud#fraud-prevention","content":"Ambriel's Digital Footprint capabilities provide critical data for fraud prevention by revealing patterns of online behavior, identifying suspicious activity, and verifying the authenticity of user profiles. The Email API, Phone API, and IP API offer rich insights into linked profiles, data breaches, and the reputation of contact details. These tools help detect fraudulent behaviors early, such as disposable emails, suspicious IP addresses, and potentially compromised phone numbers."},"508":{"id":"/docs/ui/fraud/fraud-14","page_id":"/docs/ui/fraud/fraud","type":"text","url":"/docs/ui/fraud/fraud#device-intelligence","content":"The Device Intelligence suite, available through Ambriel's Device Fingerprinting SDKs and the Fraud API, enables businesses to track device attributes, behavioral biometrics, and patterns of interaction. By collecting data on device configurations, browser settings, and user behaviors, Ambriel helps detect bot activity, device spoofing, and multi-accounting attempts. This proactive layer of protection supports both real-time threat detection and ongoing monitoring."},"509":{"id":"/docs/ui/fraud/fraud-15","page_id":"/docs/ui/fraud/fraud","type":"text","url":"/docs/ui/fraud/fraud#aml-and-compliance","content":"Ambriel offers a suite of Anti-Money Laundering (AML) compliance tools designed to simplify regulatory adherence while enhancing fraud detection capabilities. These tools integrate seamlessly with the Fraud API, providing a holistic approach to financial crime prevention."},"510":{"id":"/docs/ui/fraud/scoring-engine","page_id":"/docs/ui/fraud/scoring-engine","type":"page","content":"Scoring Engine","url":"/docs/ui/fraud/scoring-engine"},"511":{"id":"/docs/ui/fraud/scoring-engine-0","page_id":"/docs/ui/fraud/scoring-engine","type":"text","url":"/docs/ui/fraud/scoring-engine","content":"A comprehensive system for defining and applying custom rules to evaluate and score transactions based on various attributes including IP addresses, customer data, phone numbers, emails, BINs, and transaction details."},"512":{"id":"/docs/ui/fraud/scoring-engine-1","page_id":"/docs/ui/fraud/scoring-engine","type":"heading","url":"/docs/ui/fraud/scoring-engine#scoring-engine","content":"Scoring Engine"},"513":{"id":"/docs/ui/fraud/scoring-engine-2","page_id":"/docs/ui/fraud/scoring-engine","type":"heading","url":"/docs/ui/fraud/scoring-engine#configuring-the-scoring-engine","content":"Configuring the Scoring Engine"},"514":{"id":"/docs/ui/fraud/scoring-engine-3","page_id":"/docs/ui/fraud/scoring-engine","type":"heading","url":"/docs/ui/fraud/scoring-engine#rule-types","content":"Rule Types"},"515":{"id":"/docs/ui/fraud/scoring-engine-4","page_id":"/docs/ui/fraud/scoring-engine","type":"heading","url":"/docs/ui/fraud/scoring-engine#conditions","content":"Conditions"},"516":{"id":"/docs/ui/fraud/scoring-engine-5","page_id":"/docs/ui/fraud/scoring-engine","type":"heading","url":"/docs/ui/fraud/scoring-engine#actions","content":"Actions"},"517":{"id":"/docs/ui/fraud/scoring-engine-6","page_id":"/docs/ui/fraud/scoring-engine","type":"heading","url":"/docs/ui/fraud/scoring-engine#examples","content":"Examples"},"518":{"id":"/docs/ui/fraud/scoring-engine-7","page_id":"/docs/ui/fraud/scoring-engine","type":"text","url":"/docs/ui/fraud/scoring-engine#scoring-engine","content":"Scoring Engine is a powerful tool that enables you to define custom rules for scoring transactions. It is composed of several rule types, including IP Rules, Customer Rules, Phone Rules, Email Rules, Bin Rules, and Transaction Rules. Rules can be combined with logical operators to create complex rules."},"519":{"id":"/docs/ui/fraud/scoring-engine-8","page_id":"/docs/ui/fraud/scoring-engine","type":"text","url":"/docs/ui/fraud/scoring-engine#scoring-engine","content":"The Scoring Engine works by allowing you to define a set of rules that are evaluated for each transaction. Each rule has a set of conditions that are evaluated, and if all conditions are true, the rule is triggered. The triggered rule can then perform an action, such as setting a score, setting a state (Approve, Reject, Review), or adding a value to a list."},"520":{"id":"/docs/ui/fraud/scoring-engine-9","page_id":"/docs/ui/fraud/scoring-engine","type":"text","url":"/docs/ui/fraud/scoring-engine#configuring-the-scoring-engine","content":"The Scoring Engine is configured by defining a set of rules. Each rule has a name, a type, and a set of conditions."},"521":{"id":"/docs/ui/fraud/scoring-engine-10","page_id":"/docs/ui/fraud/scoring-engine","type":"text","url":"/docs/ui/fraud/scoring-engine#rule-types","content":"The following rule types are available:"},"522":{"id":"/docs/ui/fraud/scoring-engine-11","page_id":"/docs/ui/fraud/scoring-engine","type":"text","url":"/docs/ui/fraud/scoring-engine#rule-types","content":"Rule Type"},"523":{"id":"/docs/ui/fraud/scoring-engine-12","page_id":"/docs/ui/fraud/scoring-engine","type":"text","url":"/docs/ui/fraud/scoring-engine#rule-types","content":"Description"},"524":{"id":"/docs/ui/fraud/scoring-engine-13","page_id":"/docs/ui/fraud/scoring-engine","type":"text","url":"/docs/ui/fraud/scoring-engine#rule-types","content":"IP Rule"},"525":{"id":"/docs/ui/fraud/scoring-engine-14","page_id":"/docs/ui/fraud/scoring-engine","type":"text","url":"/docs/ui/fraud/scoring-engine#rule-types","content":"Evaluates the IP address of the transaction."},"526":{"id":"/docs/ui/fraud/scoring-engine-15","page_id":"/docs/ui/fraud/scoring-engine","type":"text","url":"/docs/ui/fraud/scoring-engine#rule-types","content":"Customer Rule"},"527":{"id":"/docs/ui/fraud/scoring-engine-16","page_id":"/docs/ui/fraud/scoring-engine","type":"text","url":"/docs/ui/fraud/scoring-engine#rule-types","content":"Evaluates the customer information associated with the transaction."},"528":{"id":"/docs/ui/fraud/scoring-engine-17","page_id":"/docs/ui/fraud/scoring-engine","type":"text","url":"/docs/ui/fraud/scoring-engine#rule-types","content":"Phone Rule"},"529":{"id":"/docs/ui/fraud/scoring-engine-18","page_id":"/docs/ui/fraud/scoring-engine","type":"text","url":"/docs/ui/fraud/scoring-engine#rule-types","content":"Evaluates the phone number associated with the transaction."},"530":{"id":"/docs/ui/fraud/scoring-engine-19"