age_id":"/docs/ui/integration/bigcommerce","type":"page","content":"BigCommerce","url":"/docs/ui/integration/bigcommerce"},"584":{"id":"/docs/ui/integration/bigcommerce-0","page_id":"/docs/ui/integration/bigcommerce","type":"text","url":"/docs/ui/integration/bigcommerce","content":"Integration with BigCommerce"},"585":{"id":"/docs/ui/integration/bigcommerce-1","page_id":"/docs/ui/integration/bigcommerce","type":"heading","url":"/docs/ui/integration/bigcommerce#in-progress","content":"In Progress"},"586":{"id":"/docs/ui/integration/bigcommerce-2","page_id":"/docs/ui/integration/bigcommerce","type":"text","url":"/docs/ui/integration/bigcommerce#in-progress","content":"This page is currently being worked on and will be available soon."},"587":{"id":"/docs/ui/integration","page_id":"/docs/ui/integration","type":"page","content":"Getting Started","url":"/docs/ui/integration"},"588":{"id":"/docs/ui/integration-0","page_id":"/docs/ui/integration","type":"text","url":"/docs/ui/integration","content":"Learn how to integrate Ambriel with your existing services"},"589":{"id":"/docs/ui/integration-1","page_id":"/docs/ui/integration","type":"heading","url":"/docs/ui/integration#api-reference","content":"API Reference"},"590":{"id":"/docs/ui/integration-2","page_id":"/docs/ui/integration","type":"heading","url":"/docs/ui/integration#javascript-agent","content":"Javascript Agent"},"591":{"id":"/docs/ui/integration-3","page_id":"/docs/ui/integration","type":"heading","url":"/docs/ui/integration#e-commerce-plugins","content":"E-commerce Plugins"},"592":{"id":"/docs/ui/integration-4","page_id":"/docs/ui/integration","type":"heading","url":"/docs/ui/integration#whats-next","content":"What's Next?"},"593":{"id":"/docs/ui/integration-5","page_id":"/docs/ui/integration","type":"text","url":"/docs/ui/integration","content":"Ambriel provides a range of integration options to help you get started quickly. Whether you're building a custom integration or using one of our pre-built plugins, we've got you covered."},"594":{"id":"/docs/ui/integration-6","page_id":"/docs/ui/integration","type":"text","url":"/docs/ui/integration","content":"By integrating Ambriel with your existing services, you can create a seamless experience for integration. You can use Ambriel as if it were your own product, without needing to map any data or use new identifiers."},"595":{"id":"/docs/ui/integration-7","page_id":"/docs/ui/integration","type":"text","url":"/docs/ui/integration","content":"You can use your own identifiers, such as customer_id, order_id, transaction_id, and more. This makes it easy to incorporate Ambriel into your existing workflows and processes, without having to make significant changes to your code or infrastructure."},"596":{"id":"/docs/ui/integration-8","page_id":"/docs/ui/integration","type":"text","url":"/docs/ui/integration#api-reference","content":"If you're looking to build a custom integration, our API Reference is the perfect place to start. You'll find detailed documentation on all of our endpoints, including examples and code snippets to help you get started."},"597":{"id":"/docs/ui/integration-9","page_id":"/docs/ui/integration","type":"text","url":"/docs/ui/integration#javascript-agent","content":"Our Javascript Agent provides a simple way to integrate Ambriel with your web application. You can use it to capture user data, track events, and trigger fraud checks."},"598":{"id":"/docs/ui/integration-10","page_id":"/docs/ui/integration","type":"text","url":"/docs/ui/integration#e-commerce-plugins","content":"We also provide pre-built plugins for popular e-commerce platforms like Woocommerce, Wix, Shopify, and BigCommerce. These plugins make it easy to integrate Ambriel with your online store, and provide a seamless experience for your customers."},"599":{"id":"/docs/ui/integration-11","page_id":"/docs/ui/integration","type":"text","url":"/docs/ui/integration#whats-next","content":"Once you've chosen an integration method, you can start building your Ambriel integration. If you have any questions or need help along the way, our support team is here to help."},"600":{"id":"/docs/ui/integration/js-agent","page_id":"/docs/ui/integration/js-agent","type":"page","content":"JavaScript Agent","url":"/docs/ui/integration/js-agent"},"601":{"id":"/docs/ui/integration/js-agent-0","page_id":"/docs/ui/integration/js-agent","type":"text","url":"/docs/ui/integration/js-agent","content":"Integration of Ambriel's JavaScript Agent into your web applications"},"602":{"id":"/docs/ui/integration/js-agent-1","page_id":"/docs/ui/integration/js-agent","type":"heading","url":"/docs/ui/integration/js-agent#integrate-our-javascript-agent","content":"Integrate our JavaScript Agent"},"603":{"id":"/docs/ui/integration/js-agent-2","page_id":"/docs/ui/integration/js-agent","type":"heading","url":"/docs/ui/integration/js-agent#installation","content":"Installation"},"604":{"id":"/docs/ui/integration/js-agent-3","page_id":"/docs/ui/integration/js-agent","type":"heading","url":"/docs/ui/integration/js-agent#add-tracking-script-to-your-website","content":"Add tracking script to your website"},"605":{"id":"/docs/ui/integration/js-agent-4","page_id":"/docs/ui/integration/js-agent","type":"heading","url":"/docs/ui/integration/js-agent#add-session-id-to-your-transaction-payload","content":"Add session ID to your transaction payload"},"606":{"id":"/docs/ui/integration/js-agent-5","page_id":"/docs/ui/integration/js-agent","type":"heading","url":"/docs/ui/integration/js-agent#send-session-to-ambriel-api","content":"Send session to Ambriel Api"},"607":{"id":"/docs/ui/integration/js-agent-6","page_id":"/docs/ui/integration/js-agent","type":"text","url":"/docs/ui/integration/js-agent#integrate-our-javascript-agent","content":"The Ambriel JavaScript Agent is a lightweight library that allows you to easily integrate Ambriel's features into your web applications. It provides a simple API to track user interactions, manage sessions, and send data to the A