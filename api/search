/kyb/risk-assessment-0","page_id":"/docs/ui/kyb/risk-assessment","type":"text","url":"/docs/ui/kyb/risk-assessment","content":"Learn about KYB (Know Your Business) compliance requirements and how Ambriel helps verify business identities, screen against sanctions lists, and maintain regulatory compliance."},"627":{"id":"/docs/ui/kyb/risk-assessment-1","page_id":"/docs/ui/kyb/risk-assessment","type":"heading","url":"/docs/ui/kyb/risk-assessment#what-is-kyb-compliance","content":"What is KYB Compliance?"},"628":{"id":"/docs/ui/kyb/risk-assessment-2","page_id":"/docs/ui/kyb/risk-assessment","type":"heading","url":"/docs/ui/kyb/risk-assessment#what-does-ambriels-kyb-risk-assessment-solution-do","content":"What does Ambriel's KYB Risk Assessment solution do?"},"629":{"id":"/docs/ui/kyb/risk-assessment-3","page_id":"/docs/ui/kyb/risk-assessment","type":"heading","url":"/docs/ui/kyb/risk-assessment#screening","content":"Screening"},"630":{"id":"/docs/ui/kyb/risk-assessment-4","page_id":"/docs/ui/kyb/risk-assessment","type":"heading","url":"/docs/ui/kyb/risk-assessment#monitoring","content":"Monitoring"},"631":{"id":"/docs/ui/kyb/risk-assessment-5","page_id":"/docs/ui/kyb/risk-assessment","type":"heading","url":"/docs/ui/kyb/risk-assessment#data-management","content":"Data Management"},"632":{"id":"/docs/ui/kyb/risk-assessment-6","page_id":"/docs/ui/kyb/risk-assessment","type":"heading","url":"/docs/ui/kyb/risk-assessment#how-does-it-work","content":"How does it work?"},"633":{"id":"/docs/ui/kyb/risk-assessment-7","page_id":"/docs/ui/kyb/risk-assessment","type":"text","url":"/docs/ui/kyb/risk-assessment#what-is-kyb-compliance","content":"The Financial Action Task Force (FATF) recommends that countries implement effective Anti-Money Laundering (AML) and Combating the Financing of Terrorism (CFT) regulations. The European Union's 5th and 6th Anti-Money Laundering Directives (AMLD5/6) also require businesses to verify the identity of corporate entities, assess their risk profiles, and screen against global sanction lists, PEP (Politically Exposed Persons) databases, and high-risk profiles."},"634":{"id":"/docs/ui/kyb/risk-assessment-8","page_id":"/docs/ui/kyb/risk-assessment","type":"text","url":"/docs/ui/kyb/risk-assessment#what-does-ambriels-kyb-risk-assessment-solution-do","content":"Ambriel's KYB risk assessment solution is designed to help businesses verify business identities and assess their risk exposure. It does this by providing real-time screening, monitoring, and data management capabilities."},"635":{"id":"/docs/ui/kyb/risk-assessment-9","page_id":"/docs/ui/kyb/risk-assessment","type":"text","url":"/docs/ui/kyb/risk-assessment#screening","content":"The KYB API screens businesses against global sanction lists, PEP databases, and high-risk profiles. This ensures that businesses are compliant with KYB regulations and can assess potential risks associated with business partners and customers."},"636":{"id":"/docs/ui/kyb/risk-assessment-10","page_id":"/docs/ui/kyb/risk-assessment","type":"text","url":"/docs/ui/kyb/risk-assessment#monitoring","content":"The KYB API also provides continuous monitoring, alerting businesses to any changes in a business entity's compliance status or risk profile over time."},"637":{"id":"/docs/ui/kyb/risk-assessment-11","page_id":"/docs/ui/kyb/risk-assessment","type":"text","url":"/docs/ui/kyb/risk-assessment#data-management","content":"The KYB API provides a secure and reliable way to manage business data, ensuring that it is up-to-date and accurate. Additionally, all searches and results are stored in a secure and tamper-proof log for 5 years, providing a complete audit trail."},"638":{"id":"/docs/ui/kyb/risk-assessment-12","page_id":"/docs/ui/kyb/risk-assessment","type":"text","url":"/docs/ui/kyb/risk-assessment#how-does-it-work","content":"The KYB API integrates seamlessly with the Fraud API, providing a holistic approach to business risk assessment and financial crime prevention. The KYB API is designed to be compatible with the Anti-Money Laundering Directive (AMLD5/6) of the European Union, as well as the recommendations of the Financial Action Task Force (FATF)."},"639":{"id":"/docs/ui/kyb/strategies","page_id":"/docs/ui/kyb/strategies","type":"page","content":"How does it work?","url":"/docs/ui/kyb/strategies"},"640":{"id":"/docs/ui/kyb/strategies-0","page_id":"/docs/ui/kyb/strategies","type":"text","url":"/docs/ui/kyb/strategies","content":"Learn how to integrate and utilize Ambriel's KYB (Know Your Business) compliance solutions effectively."},"641":{"id":"/docs/ui/kyb/strategies-1","page_id":"/docs/ui/kyb/strategies","type":"heading","url":"/docs/ui/kyb/strategies#kyb-risk-scoring-strategies","content":"KYB Risk Scoring Strategies"},"642":{"id":"/docs/ui/kyb/strategies-2","page_id":"/docs/ui/kyb/strategies","type":"heading","url":"/docs/ui/kyb/strategies#how-rules-work","content":"How Rules Work"},"643":{"id":"/docs/ui/kyb/strategies-3","page_id":"/docs/ui/kyb/strategies","type":"heading","url":"/docs/ui/kyb/strategies#risk-matrix-reference","content":"Risk Matrix Reference"},"644":{"id":"/docs/ui/kyb/strategies-4","page_id":"/docs/ui/kyb/strategies","type":"heading","url":"/docs/ui/kyb/strategies#three-scoring-strategies","content":"Three Scoring Strategies"},"645":{"id":"/docs/ui/kyb/strategies-5","page_id":"/docs/ui/kyb/strategies","type":"heading","url":"/docs/ui/kyb/strategies#strategy-1-cumulative-risk-sum-of-scores","content":"Strategy 1: Cumulative Risk (Sum of Scores)"},"646":{"id":"/docs/ui/kyb/strategies-6","page_id":"/docs/ui/kyb/strategies","type":"heading","url":"/docs/ui/kyb/strategies#how-it-works","content":"How It Works"},"647":{"id":"/docs/ui/kyb/strategies-7","page_id":"/docs/ui/kyb/strategies","type":"heading","url":"/docs/ui/kyb/strategies#formula","content":"Formula"},"648":{"id":"/docs/ui/kyb/strategies-8","page_id":"/docs/ui/kyb/strategies","type":"heading","url":"/docs/ui/kyb/strategies#real-world-example","content":"Real-Wor