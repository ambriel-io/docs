urrency."},"534":{"id":"/docs/ui/fraud/scoring-engine-25","page_id":"/docs/ui/fraud/scoring-engine","type":"text","url":"/docs/ui/fraud/scoring-engine#conditions","content":"Each rule can have multiple conditions. Conditions are evaluated using logical operators. The following logical operators are available:"},"535":{"id":"/docs/ui/fraud/scoring-engine-26","page_id":"/docs/ui/fraud/scoring-engine","type":"text","url":"/docs/ui/fraud/scoring-engine#conditions","content":"Operator"},"536":{"id":"/docs/ui/fraud/scoring-engine-27","page_id":"/docs/ui/fraud/scoring-engine","type":"text","url":"/docs/ui/fraud/scoring-engine#conditions","content":"Description"},"537":{"id":"/docs/ui/fraud/scoring-engine-28","page_id":"/docs/ui/fraud/scoring-engine","type":"text","url":"/docs/ui/fraud/scoring-engine#conditions","content":"AND"},"538":{"id":"/docs/ui/fraud/scoring-engine-29","page_id":"/docs/ui/fraud/scoring-engine","type":"text","url":"/docs/ui/fraud/scoring-engine#conditions","content":"Evaluates to true if all conditions are true."},"539":{"id":"/docs/ui/fraud/scoring-engine-30","page_id":"/docs/ui/fraud/scoring-engine","type":"text","url":"/docs/ui/fraud/scoring-engine#conditions","content":"OR"},"540":{"id":"/docs/ui/fraud/scoring-engine-31","page_id":"/docs/ui/fraud/scoring-engine","type":"text","url":"/docs/ui/fraud/scoring-engine#conditions","content":"Evaluates to true if any condition is true."},"541":{"id":"/docs/ui/fraud/scoring-engine-32","page_id":"/docs/ui/fraud/scoring-engine","type":"text","url":"/docs/ui/fraud/scoring-engine#conditions","content":"NOT"},"542":{"id":"/docs/ui/fraud/scoring-engine-33","page_id":"/docs/ui/fraud/scoring-engine","type":"text","url":"/docs/ui/fraud/scoring-engine#conditions","content":"Evaluates to true if the condition is false."},"543":{"id":"/docs/ui/fraud/scoring-engine-34","page_id":"/docs/ui/fraud/scoring-engine","type":"text","url":"/docs/ui/fraud/scoring-engine#actions","content":"If a rule is triggered, the action assoc